# RivlayX — environment variables
# Copy to .env and fill in. .env is gitignored.

# ─── Database (local dev) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://rivlayx:rivlayx_dev@localhost:5432/rivlayx_dev

# ─── Safety brakes (Fase 1 — hard caps) ───────────────────────────────────
MAX_BET_USDC=25
MAX_TVL_USDC=1000
MIN_DEPOSIT_USDC=5
MAX_SINGLE_DEPOSIT_USDC=250
# Withdrawal caps — single source for request + approve + runner (P-1B).
MAX_WITHDRAW_USDC=25
MAX_DAILY_WITHDRAW_USDC=100

# ─── C5 — admin TOTP MFA ──────────────────────────────────────────────────
# Encrypts admin TOTP secrets at rest (AES-256-GCM). Base64 of 32 bytes.
# Generate with: openssl rand -base64 32 — REQUIRED in production. Placeholder
# only; never commit a real key.
# MFA_ENCRYPTION_KEY=
MFA_MAX_AGE_MINUTES=15                 # money approvals require MFA verified within this window
MFA_ISSUER=RivlayX Admin              # label shown in the authenticator app

# ─── Sprint 5 — Privy auth + embedded wallet ──────────────────────────────
# In dev/test these are optional — apps/web falls back to MockAuthProvider
# when missing. In production all four are required.
# PRIVY_APP_ID=
# NEXT_PUBLIC_PRIVY_APP_ID=          # same value, exposed to the client
# PRIVY_APP_SECRET=

# ─── Solana network + USDC (Sprint 5 / 30 / 31) ───────────────────────────
SOLANA_NETWORK=devnet                 # devnet | mainnet-beta — closed alpha = devnet
# SOLANA_RPC_URL=https://your-dedicated-devnet-rpc          # use a dedicated RPC, not the public faucet endpoint
# PLATFORM_VAULT_ATA=YourPublicVaultUsdcAta1111111111111111 # public USDC ATA for the vault (deposits target this)
# SOLANA_USDC_MINT=DevnetUsdcMintAddress11111111111111111   # REQUIRED in production — prevents fallback to the mainnet USDC mint on a devnet deploy

# ─── Helius webhook ingress (Sprint 30) ───────────────────────────────────
# HELIUS_API_KEY=your-helius-api-key
# HELIUS_WEBHOOK_SECRET=your-helius-webhook-hmac-secret     # HMAC-SHA256 secret verifying /api/webhooks/helius

# ─── Withdrawal payout signer (Sprint 31) — devnet only ───────────────────
# SOLANA_VAULT_SECRET_KEY=base58-encoded-vault-secret-key   # SECRET — set Encrypted in Vercel, never NEXT_PUBLIC_, never commit

# ─── Sprint 5/6 — cron + auto-resolve ─────────────────────────────────────
# Bearer secret for /api/cron/* routes (Vercel Cron sends it). Required in prod.
CRON_SECRET=
# API_FOOTBALL_KEY=
# COINGECKO_API_KEY=

# ─── Ops / health (Sprint 24) ─────────────────────────────────────────────
# OPS_HEALTH_TOKEN=random-readonly-health-token-min-16-chars # for external uptime probes (or reuse CRON_SECRET)
# OPS_PUBLIC_BASE_URL=https://your-web-deploy-domain         # absolute runbook links in dispatched ops alerts

# ─── Sprint 7 — Supabase Storage ──────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET_EVIDENCE=

# ─── Sprint 11 — Observability ────────────────────────────────────────────
# SENTRY_DSN=
