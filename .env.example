# RivlayX — environment variables
# Copy to .env and fill in. .env is gitignored.

# ─── Database (local dev) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://rivlayx:rivlayx_dev@localhost:5432/rivlayx_dev

# ─── Safety brakes (Fase 1 — hard caps) ───────────────────────────────────
MAX_BET_USDC=25
MAX_TVL_USDC=1000
MIN_DEPOSIT_USDC=5
MAX_SINGLE_DEPOSIT_USDC=250

# ─── Sprint 5 — Privy auth + embedded wallet ──────────────────────────────
# In dev/test these are optional — apps/web falls back to MockAuthProvider
# when missing. In production all four are required.
# PRIVY_APP_ID=
# NEXT_PUBLIC_PRIVY_APP_ID=          # same value, exposed to the client
# PRIVY_APP_SECRET=

# ─── Sprint 5 — Solana network ────────────────────────────────────────────
SOLANA_NETWORK=devnet
# SOLANA_RPC_URL=                    # override; defaults to public devnet
# PLATFORM_VAULT_ATA=                # public USDC ATA for the platform vault

# ─── Sprint 6+ — Helius / vault key ───────────────────────────────────────
# HELIUS_API_KEY=
# HELIUS_WEBHOOK_SECRET=
# PLATFORM_VAULT_PRIVATE_KEY_ENCRYPTED=
# PLATFORM_VAULT_ENCRYPTION_KEY=

# ─── Sprint 5/6 — cron + auto-resolve ─────────────────────────────────────
# Bearer secret for /api/cron/* routes (Vercel Cron sends it). Required in prod.
CRON_SECRET=
# API_FOOTBALL_KEY=
# COINGECKO_API_KEY=

# ─── Sprint 7 — Supabase Storage ──────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET_EVIDENCE=

# ─── Sprint 11 — Observability ────────────────────────────────────────────
# SENTRY_DSN=
